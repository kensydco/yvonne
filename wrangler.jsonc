{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yvonne-chat",
  "main": "worker.js",
  "compatibility_date": "2026-05-30",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "run_worker_first": ["/"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
